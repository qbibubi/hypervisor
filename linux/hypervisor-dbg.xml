<domain type='kvm'>
  <name>hypervisor-dbg</name>

  <memory unit='GiB'>4</memory>
  <currentMemory unit='GiB'>4</currentMemory>
  <memoryBacking>
      <source type='memfd'/>
      <access mode='shared'/>
  </memoryBacking>
  
  <vcpu placement='static'>2</vcpu>
  
  <cpu mode='host-passthrough' check='none' migratable='off'>
    <feature policy='require' name='svm'/>
    <feature policy='require' name='hypervisor'/>
    <feature policy='require' name='topoext'/>
  </cpu>

  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <loader readonly='yes' type='pflash'>/usr/share/edk2/x64/OVMF_CODE.4m.fd</loader>
    <nvram template='/usr/share/edk2/x64/OVMF_VARS.4m.fd'>/var/lib/libvirt/qemu/nvram/hypervisor-dbg_VARS.fd</nvram>
    <bootmenu enable='yes'/>
  </os>

  <channel type='unix'>
    <source mode='bind' path='/var/lib/libvirt/qemu/hypervisor-dbg.agent'/>
    <target type='virtio' name='org.qemu.guest_agent.0'/>
    <address type='virtio-serial' controller='0' bus='0' port='1'/>
  </channel>

  <features>
    <acpi/>
    <apic/>
    <hyperv mode='custom'>
      <relaxed state='on'/>
      <vapic state='on'/>
      <spinlocks state='on' retries='8191'/>
      <evmcs state='off'/>
    </hyperv>
    <kvm>
      <hidden state='on'/>
    </kvm>
    <vmport state='off'/>
    <smm state='on'/>
  </features>

  <clock offset='localtime'>
    <timer name='rtc' tickpolicy='catchup'/>
    <timer name='pit' tickpolicy='delay'/>
    <timer name='hpet' present='no'/>
    <timer name='hypervclock' present='yes'/>
  </clock>

  <devices>
    <graphics type='vnc' port='5901' autoport='no' listen='127.0.0.1'>
      <resolution width='1920' height='1080'/>
    </graphics>

    <video>
      <model type='virtio' vram='16384' heads='1' primary='yes'/>
    </video>

    <input type='tablet' bus='usb'>
      <address type='usb' bus='0' port='1'/>
    </input>

    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' cache='writeback'/>
      <source file='/var/lib/libvirt/images/windbg-debugger.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>

    <!-- Windows 10 ISO for installation -->
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='/home/qbibubi/isos/Win10_22H2_English_x64v1.iso'/>
      <target dev='sda' bus='sata'/>
      <readonly/>
    </disk>

    <!-- VirtIO ISO for drivers -->
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='/home/qbibubi/isos/virtio-win.iso'/>
      <target dev='sdb' bus='sata'/>
      <readonly/>
    </disk>

    <!-- Network -->
    <interface type='network'>
      <source network='default'/>
      <model type='virtio'/>
    </interface>

    <!-- Serial for console -->
    <serial type='tcp'>
      <source mode='bind' host='127.0.0.1' service='54321'/>
      <protocol type='telnet'/>
      <target type='isa-serial' port='0'/>
    </serial>
  </devices>
</domain>
